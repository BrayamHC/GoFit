# ══════════════════════════════════════════════════════════════════
#  GoFit Vision — Plantilla de variables de entorno
#  Copia este archivo a .env y llena los valores
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────────
APP_NAME=GoFit Vision
APP_VERSION=1.0.0
APP_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Reconocimiento facial ─────────────────────────────────────────
TOLERANCE=0.6

# ── NestJS (Backend) ──────────────────────────────────────────────
NESTJS_URL=http://localhost:3000
NESTJS_ENCODINGS_PATH=/api/registros-faciales/encodings